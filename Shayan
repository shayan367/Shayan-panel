    {'title': 'Glass Agency', 'year': '1998', 'genre': 'Action', 'rating': '7.5', 'link': 'https://www.imdb.com/title/tt0166950/'},
    {'title': 'Simorgh', 'year': '2020', 'genre': 'Drama', 'rating': '7.2', 'link': 'https://www.imdb.com/title/tt13451198/'},
